#!/usr/bin/env bash
# scripts/setup-deps — install OS packages required by the selected env.
#
# This script is the dependencies executor. It is normally invoked by the
# root `./setup --<env>` orchestrator, but it can also be run directly:
#
#     scripts/setup-deps [--omarchy|--fedora] [--dry-run] [--help]
#
# When the root `./setup` orchestrator invokes it, the selected environment
# is passed through the `DOTFILES_ENV` environment variable and the dry-run
# mode through `DOTFILES_DRY_RUN=1`. Either an explicit flag or the env
# variable works.
#
# For each env, the script verifies whether each package is already
# installed (via the package manager) and installs only the missing ones.
# Re-running is a no-op.
#
# Omarchy / Arch:
#   - Package manager: yay (AUR helper, wraps pacman)
#   - Install command: yay -S --needed <pkg>
#   - Verify installed: pacman -Q <pkg>
#
# Fedora:
#   - Package manager: dnf (system)
#   - Install command: sudo dnf install -y <pkg>
#   - Verify installed: rpm -q <pkg> (fallback: dnf list installed <pkg>)
#
# Notes:
#   - Package names do not always match the command they provide (e.g.
#     `hunspell-en_US` on Arch vs `hunspell-en-US` on Fedora), so this
#     script checks by package name, not by `command -v`.
#   - In --dry-run mode the script reports what it would do but never
#     runs the install command. A missing package manager is only fatal
#     when an actual install is required.

set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve repo root (informational; this script does not depend on repo
# contents). When DOTFILES_ROOT is exported by the root `./setup`
# orchestrator, prefer it.
# ---------------------------------------------------------------------------
SCRIPT_PATH="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
if [[ -n "${DOTFILES_ROOT:-}" ]]; then
    REPO_ROOT="$DOTFILES_ROOT"
else
    REPO_ROOT="$(cd -- "$SCRIPT_PATH/.." && pwd)"
fi

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------
DOTFILES_ENV_LOCAL="${DOTFILES_ENV:-}"
DRY_RUN=0
REQUEST_HELP=0

# Package lists per env. Names match the native package manager
# (pacman on Arch, dnf on Fedora). Comments next to each package note
# the command the package provides when the names diverge.
OMARCHY_PACKAGES=(
    lsof
    hunspell
    hunspell-en_us      # command: hunspell
    hunspell-es_any     # command: hunspell
    zellij              # command: zellij
)

FEDORA_PACKAGES=(
    lsof
    hunspell
    hunspell-en-US      # command: hunspell
    hunspell-es         # command: hunspell
)

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
    cat <<EOF
Usage: $0 [--omarchy|--fedora] [--dry-run] [--help]

Installs the OS packages required by the selected environment.

This script is the dependencies executor. Prefer invoking it via the root
entrypoint: \`./setup --<env> [--fonts] [--dry-run]\`.

When the root \`./setup\` orchestrator calls this script, it passes the
selected environment through \`DOTFILES_ENV\` and the dry-run mode
through \`DOTFILES_DRY_RUN=1\`. Either works as input.

Environment selection (in order of precedence):
  1. Explicit flag: --omarchy or --fedora on the command line
     (overrides auto-detection; useful for chroots, toolboxes, and
     deterministic test fixtures).
  2. DOTFILES_ENV: 'omarchy' or 'fedora' (set by the root orchestrator).
  3. Auto-detection: probe the host PATH in this fixed order:
       yay    → omarchy   (AUR helper is the documented Omarchy entry)
       pacman → omarchy   (with WARN: install yay for AUR access)
       dnf    → fedora    (canonical Fedora package manager)
       rpm    → fedora    (with WARN: install dnf)
     If none of these is on PATH, this script exits non-zero with
     "Could not detect a supported package manager".

Options:
  --dry-run    Print what would be installed without running the
               package manager. Re-running the actual install is a
               no-op when every package is already present.
  --help, -h   Show this help and exit.

Packages (verified with the package manager, not 'command -v'):

  Omarchy: ${OMARCHY_PACKAGES[*]}
  Fedora:  ${FEDORA_PACKAGES[*]}
EOF
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
while [[ $# -gt 0 ]]; do
    case "$1" in
        --omarchy)
            DOTFILES_ENV_LOCAL="omarchy"
            shift
            ;;
        --fedora)
            DOTFILES_ENV_LOCAL="fedora"
            shift
            ;;
        --dry-run)
            DRY_RUN=1
            shift
            ;;
        --help | -h)
            REQUEST_HELP=1
            shift
            ;;
        *)
            echo "Unknown argument: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

if [[ "$REQUEST_HELP" -eq 1 ]]; then
    usage
    exit 0
fi

# Promote DOTFILES_DRY_RUN=1 to DRY_RUN=1 when invoked by the orchestrator
# without an explicit --dry-run flag. The root setup exports it explicitly
# when --dry-run is set; both signals agree in that case.
if [[ -n "${DOTFILES_DRY_RUN:-}" && "$DOTFILES_DRY_RUN" == "1" ]]; then
    DRY_RUN=1
fi

# ---------------------------------------------------------------------------
# Logging helpers
# ---------------------------------------------------------------------------
log() {
    echo "[setup-deps] $*"
}

warn() {
    echo "[setup-deps] WARN: $*" >&2
}

fail() {
    echo "[setup-deps] ERROR: $*" >&2
    exit 1
}

# ---------------------------------------------------------------------------
# Environment detection
# ---------------------------------------------------------------------------
# Probe package managers in the documented order. Echoes the detected
# env ("omarchy" or "fedora") on stdout. Returns 0 on success, 1 when
# no supported package manager is on PATH. Detection is purely a probe:
# the script never calls `command -v` on a tool it then needs to install.
detect_env() {
    if command -v yay >/dev/null 2>&1; then
        printf 'omarchy\n'
        return 0
    fi
    if command -v pacman >/dev/null 2>&1; then
        warn "yay is not on PATH; install it for AUR access. Detecting as omarchy via pacman."
        printf 'omarchy\n'
        return 0
    fi
    if command -v dnf >/dev/null 2>&1; then
        printf 'fedora\n'
        return 0
    fi
    if command -v rpm >/dev/null 2>&1; then
        warn "dnf is not on PATH; install it. Detecting as fedora via rpm."
        printf 'fedora\n'
        return 0
    fi
    return 1
}

# ---------------------------------------------------------------------------
# Validation
# ---------------------------------------------------------------------------
# When neither an explicit flag nor DOTFILES_ENV is set, auto-detect
# the host by probing package managers. When detection fails, exit
# with a clear, actionable message.
if [[ -z "$DOTFILES_ENV_LOCAL" ]]; then
    if detected_env="$(detect_env)"; then
        DOTFILES_ENV_LOCAL="$detected_env"
        log "Detected env: $DOTFILES_ENV_LOCAL (no --omarchy/--fedora passed)"
    else
        cat >&2 <<EOF
ERROR: Could not detect a supported package manager (yay, pacman, dnf, rpm). Install one and re-run.
EOF
        usage >&2
        exit 2
    fi
fi

# ---------------------------------------------------------------------------
# Package manager helpers
# ---------------------------------------------------------------------------
# Echo the install command for a single package. Printf is safe here:
# packages are hard-coded (no untrusted input).
pm_install_cmd() {
    local pkg="$1"
    case "$DOTFILES_ENV_LOCAL" in
        omarchy)
            printf 'yay -S --needed %s\n' "$pkg"
            ;;
        fedora)
            printf 'sudo dnf install -y %s\n' "$pkg"
            ;;
    esac
}

# Verify a package is installed using the native package manager.
# Returns 0 if installed, non-zero otherwise. In dry-run mode, missing
# verification tooling does not fail; the package is conservatively
# treated as missing so the dry-run report still shows the would-be
# install command.
pkg_installed() {
    local pkg="$1"
    case "$DOTFILES_ENV_LOCAL" in
        omarchy)
            if ! command -v pacman >/dev/null 2>&1; then
                if [[ "$DRY_RUN" -eq 1 ]]; then
                    warn "pacman not on PATH; cannot verify '$pkg' in dry-run. Assuming missing."
                    return 1
                fi
                fail "pacman is not on PATH; cannot verify packages on Omarchy."
            fi
            pacman -Q "$pkg" >/dev/null 2>&1
            ;;
        fedora)
            if command -v rpm >/dev/null 2>&1; then
                rpm -q "$pkg" >/dev/null 2>&1
            elif command -v dnf >/dev/null 2>&1; then
                dnf list installed "$pkg" >/dev/null 2>&1
            else
                if [[ "$DRY_RUN" -eq 1 ]]; then
                    warn "Neither rpm nor dnf on PATH; cannot verify '$pkg' in dry-run. Assuming missing."
                    return 1
                fi
                fail "Neither rpm nor dnf is on PATH; cannot verify packages on Fedora."
            fi
            ;;
    esac
}

# Install a single package. In dry-run, log the action and return.
# In real mode, require the package manager up front and run it.
install_package() {
    local pkg="$1"
    local cmd
    cmd="$(pm_install_cmd "$pkg")"

    if [[ "$DRY_RUN" -eq 1 ]]; then
        log "[dry-run] would run: $cmd"
        return 0
    fi

    # Real install path: require the package manager.
    case "$DOTFILES_ENV_LOCAL" in
        omarchy)
            if ! command -v yay >/dev/null 2>&1; then
                fail "yay is not on PATH; install it before running setup-deps for Omarchy."
            fi
            ;;
        fedora)
            if ! command -v dnf >/dev/null 2>&1; then
                fail "dnf is not on PATH; install it before running setup-deps for Fedora."
            fi
            ;;
    esac

    log "Installing missing package '$pkg'..."
    case "$DOTFILES_ENV_LOCAL" in
        omarchy)
            yay -S --needed "$pkg"
            ;;
        fedora)
            sudo dnf install -y "$pkg"
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
    local packages=()
    case "$DOTFILES_ENV_LOCAL" in
        omarchy)
            packages=("${OMARCHY_PACKAGES[@]}")
            ;;
        fedora)
            packages=("${FEDORA_PACKAGES[@]}")
            ;;
    esac

    log "Repo root: $REPO_ROOT"
    log "Env:       $DOTFILES_ENV_LOCAL"
    if [[ "$DRY_RUN" -eq 1 ]]; then
        log "Mode:      DRY-RUN (no package manager actions)"
    fi

    log "Checking ${#packages[@]} package(s)..."

    local installed=0
    local missing=0
    local pkg
    for pkg in "${packages[@]}"; do
        if pkg_installed "$pkg"; then
            log "  [ok]   $pkg"
            installed=$((installed + 1))
        else
            log "  [miss] $pkg"
            missing=$((missing + 1))
            install_package "$pkg"
        fi
    done

    if [[ "$DRY_RUN" -eq 1 ]]; then
        log "DRY-RUN summary: $installed present, $missing would-be-installed."
    else
        log "Summary: $installed already present, $missing newly installed."
    fi

    log "Setup complete."
}

main "$@"
