#!/usr/bin/env bash
# scripts/setup-omarchy — apply this repo's Omarchy config to a local Omarchy install.
#
# This script is the Omarchy-specific executor. It is normally invoked by the
# root `./setup --omarchy` orchestrator, but it can also be run directly:
#
#     scripts/setup-omarchy [--dry-run] [--help]
#
# Supports installs created from the Omarchy ISO, Arch + Omarchy layer, and
# CachyOS minimal + Omarchy layer. This script does NOT install Omarchy; it
# only connects an existing install to the dotfiles in this repository.
#
# Env-script ownership (the new contract):
#   This script owns the full Omarchy env flow: install OS dependencies
#   (via scripts/setup-deps), install Nerd Fonts (via scripts/setup-fonts),
#   pre-flight the fonts directory, apply the symlink map, and validate
#   the system. The root `./setup` is a thin dispatcher; it does not
#   coordinate this flow.
#
# Pre-requisites (not installed by this script):
#   - `omarchy` command on PATH
#   - `hyprctl` available (a running Hyprland session)
#
# Existing files at symlink targets are moved to
#   <repo>/backup/<timestamp>/<home-relative-path>
# before being replaced by symlinks pointing into the repo.
#
# SSH config is NOT symlinked. Setup copies the tracked safe template
# at `src/home/.ssh-shadow/config` (will live at `src/home/.ssh/config`
# after WU-4) to `~/.ssh/config` (mode 600) only when
# the source exists and the local target does not. The local file
# always wins. The repo template must contain no secrets or real
# production values — see docs/ssh.md.
#
# Fonts are installed by the env flow itself (Step 2/5). When this
# script is run directly without going through root, the fonts dir
# location is read from $DOTFILES_FONTS_DIR (set by root to
# $HOME/.local/share/fonts/autanasoft) or, when unset, defaults to
# the same path.

set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve repo root from this script's path (CWD-independent).
# When invoked by the root `./setup` orchestrator, DOTFILES_ROOT is exported
# and used as the source of truth; otherwise we derive it from this file's
# location (scripts/..).
# ---------------------------------------------------------------------------
if [[ -n "${DOTFILES_ROOT:-}" ]]; then
    REPO_ROOT="$DOTFILES_ROOT"
else
    SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
    REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"
fi

# ---------------------------------------------------------------------------
# Mode parsing
# ---------------------------------------------------------------------------
DRY_RUN=0
if [[ -n "${DOTFILES_DRY_RUN:-}" && "$DOTFILES_DRY_RUN" == "1" ]]; then
    DRY_RUN=1
fi

usage() {
    cat <<EOF
Usage: $0 [--dry-run] [--help]

Applies the Omarchy dotfiles in this repo to the local Omarchy install.

This script is the Omarchy executor. Prefer invoking it via the root
entrypoint: \`./setup --omarchy [--fonts] [--dry-run]\`.

Options:
  --dry-run    Print actions without modifying the system. Skips
               symlink moves, SSH config copy, 'omarchy theme',
               'hyprctl', and font downloads.
  --help, -h   Show this help and exit.

Pre-requisites:
  - 'omarchy' command on PATH
  - 'hyprctl' available (a running Hyprland session)
  - System packages and Nerd Fonts are handled by this script through
    scripts/setup-deps and scripts/setup-fonts.

Existing targets are moved to:
  $REPO_ROOT/backup/<timestamp>/<home-relative-path>

Fonts are installed by this script as part of the Omarchy setup flow.
For fonts-only setup, use:
  ./setup --fonts
  scripts/setup-fonts --help
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run)
            DRY_RUN=1
            shift
            ;;
        --help | -h)
            usage
            exit 0
            ;;
        *)
            echo "Unknown argument: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

# ---------------------------------------------------------------------------
# Logging helpers
# ---------------------------------------------------------------------------
log() {
    echo "[setup-omarchy] $*"
}

warn() {
    echo "[setup-omarchy] WARN: $*" >&2
}

fail() {
    echo "[setup-omarchy] ERROR: $*" >&2
    exit 1
}

# ---------------------------------------------------------------------------
# Pre-flight checks
# ---------------------------------------------------------------------------
require_command() {
    local cmd="$1"
    if ! command -v "$cmd" >/dev/null 2>&1; then
        fail "Required command '$cmd' is not on PATH. Install it before running this script."
    fi
}

# ---------------------------------------------------------------------------
# Subprocess invocation helpers (env-script owns the full flow)
# ---------------------------------------------------------------------------
# Invoke scripts/setup-deps as a subprocess, passing the dry-run flag
# through. In PR-2 setup-deps still requires an explicit env flag, so
# we pass --omarchy (this script is the omarchy executor). In PR-3
# setup-deps will gain auto-detection; the explicit flag will remain
# valid as an override. Errors propagate (the env script's `set -e`
# trips on a non-zero child exit).
invoke_setup_deps() {
    local script_dir
    script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
    local deps_script="$script_dir/setup-deps"
    if [[ ! -x "$deps_script" ]]; then
        fail "Required helper script missing or not executable: $deps_script"
    fi
    local -a args=(--omarchy)
    if [[ "$DRY_RUN" -eq 1 ]]; then
        args+=(--dry-run)
    fi
    log "Invoking $deps_script ${args[*]}"
    "$deps_script" "${args[@]}"
}

# Invoke scripts/setup-fonts as a subprocess, passing the dry-run flag
# through. The fonts script reads $DOTFILES_FONTS_DIR (set by root or
# by direct callers) so the override path crosses the process boundary
# automatically.
invoke_setup_fonts() {
    local script_dir
    script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
    local fonts_script="$script_dir/setup-fonts"
    if [[ ! -x "$fonts_script" ]]; then
        fail "Required helper script missing or not executable: $fonts_script"
    fi
    local -a args=()
    if [[ "$DRY_RUN" -eq 1 ]]; then
        args+=(--dry-run)
    fi
    log "Invoking $fonts_script ${args[*]}"
    "$fonts_script" "${args[@]}"
}

# ---------------------------------------------------------------------------
# Backup helper
# ---------------------------------------------------------------------------
# Compute a backup path for an existing target under
#   $REPO_ROOT/backup/<timestamp>/<home-relative-path>
# If that path already exists, append a numeric suffix to avoid overwriting
# a previous backup. Echoes the final backup path.
backup_target() {
    local target="$1"  # absolute target path
    local stamp="$2"
    local rel

    if [[ "$target" == "$HOME" ]]; then
        rel=""
    elif [[ "$target" == "$HOME"/* ]]; then
        rel="${target#"$HOME"/}"
    else
        # Target is outside $HOME; preserve the absolute path under backup/
        # by replacing the leading slash with an underscore.
        rel="${target//\//_}"
        rel="${rel#_}"
    fi

    local backup_path="$REPO_ROOT/backup/$stamp/$rel"
    local parent
    parent="$(dirname -- "$backup_path")"

    if [[ -z "$rel" ]]; then
        # Backing up $HOME itself isn't something we do, but guard anyway.
        fail "Refusing to back up \$HOME: $target"
    fi

    if [[ -e "$backup_path" || -L "$backup_path" ]]; then
        local i=1
        while [[ -e "$backup_path.$i" || -L "$backup_path.$i" ]]; do
            i=$((i + 1))
        done
        backup_path="$backup_path.$i"
    fi

    printf '%s\n' "$backup_path"
}

# ---------------------------------------------------------------------------
# Symlink helper
# ---------------------------------------------------------------------------
# Idempotently ensure $target is a symlink pointing to $source.
#   - If $target already points (after resolving) to the same real path as
#     $source, do nothing.
#   - Otherwise, back up $target to the timestamped backup dir and create a
#     fresh symlink.
ensure_symlink() {
    local source="$1"  # absolute source path in the repo
    local target="$2"  # absolute target path under $HOME
    local stamp="$3"

    if [[ ! -e "$source" && ! -L "$source" ]]; then
        fail "Source does not exist: $source"
    fi

    # Already linked to the right thing? Leave it alone.
    if [[ -L "$target" ]]; then
        local resolved_target resolved_source
        resolved_target="$(readlink -f -- "$target" 2>/dev/null || true)"
        resolved_source="$(readlink -f -- "$source" 2>/dev/null || true)"
        if [[ -n "$resolved_target" && "$resolved_target" == "$resolved_source" ]]; then
            log "Already linked: $target"
            return 0
        fi
    fi

    # Target exists (regular file, dir, or wrong symlink) — back it up.
    if [[ -e "$target" || -L "$target" ]]; then
        local backup_path
        backup_path="$(backup_target "$target" "$stamp")"
        log "Backing up existing target: $target -> $backup_path"
        if [[ "$DRY_RUN" -eq 0 ]]; then
            mkdir -p "$(dirname -- "$backup_path")"
            mv "$target" "$backup_path"
        fi
    fi

    log "Creating symlink: $target -> $source"
    if [[ "$DRY_RUN" -eq 0 ]]; then
        mkdir -p "$(dirname -- "$target")"
        # -f forces overwrite (handles external watchers like
        # omarchy-hyprland-monitor-watch recreating the file as a stub
        # between backup and symlink). -n prevents following a symlink
        # to a directory target.
        ln -sfn "$source" "$target"
    fi
}

# ---------------------------------------------------------------------------
# SSH config seeding
# ---------------------------------------------------------------------------
# Copy the tracked safe SSH template from the repo to $HOME/.ssh/config
# when the source exists. The repo file MUST stay placeholder-only
# (no real hostnames, users, or identity file paths) — it is a
# template, not a real config. The local file at $HOME/.ssh/config
# has priority: if it already exists, the copy is skipped and a
# message is logged. Directory and file modes are enforced:
# $HOME/.ssh is 700, $HOME/.ssh/config is 600.
seed_ssh_config() {
    local src="$REPO_ROOT/src/home/.ssh-shadow/config"
    local ssh_dir="$HOME/.ssh"
    local target="$ssh_dir/config"

    if [[ ! -e "$src" && ! -L "$src" ]]; then
        log "No shared SSH template at $src; skipping (create it to seed ~/.ssh/config)."
        return 0
    fi

    # Local target has priority: never overwrite.
    if [[ -e "$target" || -L "$target" ]]; then
        log "Skipping SSH config seed: $target already exists (local file has priority)."
        return 0
    fi

    log "Seeding SSH config: $src -> $target (mode 600)"
    if [[ "$DRY_RUN" -eq 1 ]]; then
        if [[ ! -d "$ssh_dir" ]]; then
            log "[dry-run] would create directory: $ssh_dir (mode 700)"
        fi
        log "[dry-run] would copy: $src -> $target (mode 600)"
        return 0
    fi

    if [[ ! -d "$ssh_dir" ]]; then
        log "Creating SSH directory: $ssh_dir (mode 700)"
        mkdir -m 700 "$ssh_dir"
    fi
    install -m 600 "$src" "$target"
}

# ---------------------------------------------------------------------------
# Apply symlink map
# ---------------------------------------------------------------------------
apply_symlinks() {
    local stamp="$1"

    # nvim and zellij: folder symlinks (tracked source under the shadow
    # layer until WU-4 promotes shadow → final paths).
    ensure_symlink \
        "$REPO_ROOT/src/home/config-shadow/nvim" \
        "$HOME/.config/nvim" \
        "$stamp"
    ensure_symlink \
        "$REPO_ROOT/src/home/config-shadow/zellij" \
        "$HOME/.config/zellij" \
        "$stamp"

    # hypr: per-file symlinks so defaults from omarchy stay intact.
    local hypr_src
    for hypr_src in "$REPO_ROOT"/src/home/config-shadow/hypr/*.conf; do
        [[ -e "$hypr_src" ]] || continue
        ensure_symlink \
            "$hypr_src" \
            "$HOME/.config/hypr/$(basename -- "$hypr_src")" \
            "$stamp"
    done

    # waybar: tracked config file.
    ensure_symlink \
        "$REPO_ROOT/src/home/config-shadow/waybar/config.jsonc" \
        "$HOME/.config/waybar/config.jsonc" \
        "$stamp"

    # alacritty: tracked config file.
    ensure_symlink \
        "$REPO_ROOT/src/home/config-shadow/alacritty/alacritty.toml" \
        "$HOME/.config/alacritty/alacritty.toml" \
        "$stamp"

    # Theme directory: full tracked subtree.
    ensure_symlink \
        "$REPO_ROOT/src/home/config-shadow/omarchy/themes/tokyo-night-autana" \
        "$HOME/.config/omarchy/themes/tokyo-night-autana" \
        "$stamp"

    # starship.toml (tracked source under the shadow layer until WU-4).
    ensure_symlink \
        "$REPO_ROOT/src/home/config-shadow/starship.toml" \
        "$HOME/.config/starship.toml" \
        "$stamp"

    # ~/.bashrc
    ensure_symlink \
        "$REPO_ROOT/src/home/.bashrc-shadow" \
        "$HOME/.bashrc" \
        "$stamp"

    # ~/.ssh/config — copy from the tracked safe template. The local
    # file has priority (skipped if it already exists). See seed_ssh_config
    # above for the full behavior.
    seed_ssh_config

    # NOTE: src/home/local-shadow/bin/monitor is intentionally NOT
    # symlinked; it is a personal/manual script the user runs ad-hoc.
    # NOTE: src/home/config-shadow/mako/ and
    # src/home/config-shadow/omarchy/hooks/ hold no .gitkeep placeholders
    # and stay at the Omarchy default.
}

# ---------------------------------------------------------------------------
# Install keyd config + enable input-device services
# ---------------------------------------------------------------------------
# Precedent: this is the FIRST sudo service-enable touchpoint in the
# Omarchy env flow. Future env executors that need a privileged
# service-enable can use the same pattern (rely on sudo's default
# timestamp cache, 5 min — do NOT add an explicit `sudo -v` upfront).
# The two sudo calls below (`install` then `systemctl`) coalesce into
# a single password prompt because they run back-to-back inside the
# timestamp window.
#
# Order within the step: install the config FIRST, then start the
# daemon. Reversing the order would risk a daemon restart loop on a
# fresh host that has no /etc/keyd/default.conf yet (the keyd unit
# would start, fail to find its config, and keep retrying).
#
# No ~/.config/keyd/ symlink is created here: keyd runs as root and
# reads only from /etc/keyd/default.conf. The user-level path is
# unused; see docs/shared-layer.md and docs/inputs/keyboard-remap.md
# for the full reasoning.
install_input_devices() {
    local src="$REPO_ROOT/src/etc-shadow/keyd/default.conf"
    local target="/etc/keyd/default.conf"

    if [[ "$DRY_RUN" -eq 1 ]]; then
        log "[dry-run] would run: install -m 644 $src $target"
        log "[dry-run] would run: systemctl enable --now keyd ratbagd"
        return 0
    fi

    require_command install
    require_command systemctl
    log "Installing keyd config: $src -> $target (mode 644)"
    sudo install -m 644 "$src" "$target"
    log "Enabling and starting keyd + ratbagd services"
    sudo systemctl enable --now keyd ratbagd
}

# ---------------------------------------------------------------------------
# System validation: theme + reload
# ---------------------------------------------------------------------------
validate_system() {
    if [[ "$DRY_RUN" -eq 1 ]]; then
        log "[dry-run] would run: omarchy theme set tokyo-night-autana"
        log "[dry-run] would run: hyprctl reload"
        log "[dry-run] would run: hyprctl configerrors"
        log "[dry-run] would check: zellij --version (skipped if zellij is not on PATH)"
        return 0
    fi

    log "Applying Omarchy theme: tokyo-night-autana"
    omarchy theme set tokyo-night-autana

    log "Reloading Hyprland config"
    hyprctl reload

    log "Validating Hyprland config (any errors below are fatal)"
    hyprctl configerrors

    # zellij is installed by `scripts/setup-deps`. When this script is
    # run directly (without the orchestrator), zellij might be missing;
    # degrade to a soft warning instead of failing the whole run.
    if command -v zellij >/dev/null 2>&1; then
        log "Verifying zellij install"
        zellij --version
    else
        warn "zellij not on PATH; skipping version check. Run 'scripts/setup-deps --omarchy' to install it."
    fi
}

# ---------------------------------------------------------------------------
# Step counter
# ---------------------------------------------------------------------------
# The env script owns its own step counter. The 5 main steps are:
#   1. Install OS dependencies
#   2. Install Nerd Fonts
#   3. Apply symlinks
#   4. Install keyd config and enable input-device services
#   5. Validate system
# The pre-flight between steps 2 and 3 is non-mutating and is not
# counted as a step on its own.
TOTAL_STEPS=5
current_step=0

step() {
    current_step=$((current_step + 1))
    log "Step $current_step/$TOTAL_STEPS: $*"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
    local stamp
    stamp="$(date -u +%Y%m%dT%H%M%SZ)"

    log "Repo root:  $REPO_ROOT"
    log "Home:       $HOME"
    log "Timestamp:  $stamp"
    if [[ "$DRY_RUN" -eq 1 ]]; then
        log "Mode:       DRY-RUN (no system changes)"
    fi

    require_command omarchy
    require_command hyprctl

    # Step 1/5: install OS dependencies via the deps helper. In dry-run
    # the helper previews every missing package's install command.
    step "Install OS dependencies (via scripts/setup-deps)"
    invoke_setup_deps

    # Step 2/5: install Nerd Fonts via the fonts helper. Idempotent;
    # safe to re-run. In dry-run the helper previews the downloads.
    step "Install Nerd Fonts (via scripts/setup-fonts)"
    invoke_setup_fonts

    # Pre-flight: defense-in-depth for direct invocation without
    # going through root. The font install is idempotent but a missing
    # fonts dir at this point means Step 2/5 was bypassed (e.g. someone
    # ran this script directly without setup-fonts). Non-mutating:
    # we only check the directory, we never install fonts. In dry-run,
    # warn and keep previewing so a clean machine can inspect the full
    # setup flow before any downloads or symlinks happen.
    local font_dir="${DOTFILES_FONTS_DIR:-$HOME/.local/share/fonts/autanasoft}"
    log "Pre-flight fonts dir: $font_dir"
    if [[ ! -d "$font_dir" ]] || [[ -z "$(ls -A -- "$font_dir" 2>/dev/null)" ]]; then
        if [[ "$DRY_RUN" -eq 1 ]]; then
            warn "Nerd Fonts not installed under $font_dir. Continuing because this is dry-run."
        else
        fail "Nerd Fonts not installed under $font_dir. Run './setup --omarchy --fonts' first."
        fi
    fi

    # Step 3/5: apply the symlink map.
    step "Apply symlinks"
    apply_symlinks "$stamp"

    # Step 4/5: install keyd config and enable input-device services.
    # First sudo service-enable touchpoint in the env flow; both sudo
    # calls (install + systemctl) coalesce under the timestamp cache.
    step "Install keyd config and enable input-device services"
    install_input_devices

    # Step 5/5: validate the system (theme, hyprctl reload, etc.).
    step "Validate system"
    validate_system

    log "Setup complete."
}

main "$@"
