# ------------------------------------------------------------------------------
# SSH client config — safe template (TRACKED IN GIT)
# ------------------------------------------------------------------------------
# This file is a SAFE TEMPLATE: it must contain no real secrets, no real
# production hostnames, no real usernames, and no real identity file paths.
# All real values are placeholders (e.g. `your.server.ip.or.domain`,
# `your-user`) that the user fills in on the target host.
#
# Sensitive real SSH config (private keys, `known_hosts`, machine-specific
# hosts/users/identity files) belongs ONLY in the machine-local
# `~/.ssh/config`. Setup copies this template to `~/.ssh/config` ONLY when
# the target is missing; if `~/.ssh/config` already exists, setup leaves it
# alone (local file has priority).
#
# See docs/ssh.md for the full workflow.
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# GitHub
# ------------------------------------------------------------------------------

Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_github
  IdentitiesOnly yes

# ------------------------------------------------------------------------------
# Servers
# ------------------------------------------------------------------------------

Host my-server
  HostName your.server.ip.or.domain
  User admin
  IdentityFile ~/.ssh/id_ed25519_server
  IdentitiesOnly yes

Host my-database
  HostName your.database.ip.or.domain
  User admin
  IdentityFile ~/.ssh/id_ed25519_server
  IdentitiesOnly yes

Host my-work
  HostName your.work.ip.or.domain
  User your-user
  IdentityFile ~/.ssh/id_ed25519_work
  IdentitiesOnly yes
