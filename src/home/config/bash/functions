# Custom functions

# Create a Tmux Dev Layout with editor, ai, and terminal
# Usage: tal <c|cx|codex|other_ai>
tal() {
  [[ -z $1 ]] && { echo "Usage: tal <c|cx|codex|other_ai>"; return 1; }
  [[ -z $TMUX ]] && { echo "You must start tmux to use tal."; return 1; }

  local current_dir="${PWD}"
  local editor_pane ai_pane
  local ai="$1"

  # Use TMUX_PANE for the pane we're running in (stable even if active window changes)
  editor_pane="$TMUX_PANE"

  # Name the current window after the base directory name
  tmux rename-window -t "$editor_pane" "$(basename "$current_dir")"

  # Build the layout first: launching immediately after a split can land
  # send-keys before the new shell's prompt is ready.
  ai_pane=$(tmux split-window -h -p 30 -t "$editor_pane" -c "$current_dir" -P -F '#{pane_id}')
  tmux split-window -v -p 15 -t "$editor_pane" -c "$current_dir"

  # Let the new shells print their prompts before send-keys queues input.
  sleep 1

  # Launch the editor first so nvim settles its TUI before the AI starts.
  tmux send-keys -t "$editor_pane" "$EDITOR ." C-m

  # Launch the AI last and leave the focus on it so the AI's TUI init
  # sequences are routed to its own pane.
  tmux send-keys -t "$ai_pane" "$ai" C-m
  tmux select-pane -t "$ai_pane"
}
