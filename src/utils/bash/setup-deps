#!/usr/bin/env bash
# scripts/setup-deps — install OS packages required by the selected env.
#
# This script is the dependencies executor. It is normally invoked by the
# root `./setup --omarchy` orchestrator, but it can also be run directly:
#
#     scripts/setup-deps [--omarchy] [--dry-run] [--help]
#
# When the root `./setup` orchestrator invokes it, the selected environment
# is passed through the `DOTFILES_ENV` environment variable and the dry-run
# mode through `DOTFILES_DRY_RUN=1`. Either an explicit flag or the env
# variable works.
#
# For each env, the script verifies whether each package is already
# installed (via the package manager) and installs the missing ones
# in a single batch per env. Re-running is a no-op when every
# package is already present.
#
# Omarchy (Arch + Hyprland, CachyOS + Omarchy, Arch + Omarchy):
#   - Package manager: yay (AUR helper, wraps pacman)
#   - Install command: yay -S --needed <pkgs...>   (single batch)
#   - Verify installed: pacman -Q <pkg>
#
# Notes:
#   - Package names do not always match the command they provide, so this
#     script checks by package name, not by `command -v`.
#   - In --dry-run mode the script reports what it would do but never
#     runs the install command. A missing package manager is only fatal
#     when an actual install is required.

set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve repo root (informational; this script does not depend on repo
# contents). When DOTFILES_ROOT is exported by the root `./setup`
# orchestrator, prefer it.
# ---------------------------------------------------------------------------
SCRIPT_PATH="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
if [[ -n "${DOTFILES_ROOT:-}" ]]; then
    REPO_ROOT="$DOTFILES_ROOT"
else
    REPO_ROOT="$(cd -- "$SCRIPT_PATH/.." && pwd)"
fi

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------
DOTFILES_ENV_LOCAL="${DOTFILES_ENV:-}"
DRY_RUN=0
REQUEST_HELP=0

# Package list for the Omarchy-family host. Names match the native Arch
# package manager (pacman). Comments next to each package note the
# command the package provides when the names diverge.
OMARCHY_PACKAGES=(
    lsof
    hunspell
    hunspell-en_us      # command: hunspell
    hunspell-es_any     # command: hunspell
    zellij              # command: zellij
    trash-cli           # command: trash (snacks.nvim explorer delete)
    keyd                # command: keyd (keyboard remapping daemon)
    piper               # command: piper (Logitech mouse GUI; ratbagd-backed)
    libratbag           # provides: ratbagd (DBus service for Piper / mouse profiles)
)

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
    cat <<EOF
Usage: $0 [--omarchy] [--dry-run] [--help]

Installs the OS packages required by the selected environment.

This script is the dependencies executor. Prefer invoking it via the root
entrypoint: \`./setup --omarchy [--fonts] [--dry-run]\`.

When the root \`./setup\` orchestrator calls this script, it passes the
selected environment through \`DOTFILES_ENV\` and the dry-run mode
through \`DOTFILES_DRY_RUN=1\`. Either works as input.

Environment selection (in order of precedence):
  1. Explicit flag: --omarchy on the command line
     (overrides auto-detection; useful for chroots, toolboxes, and
     deterministic test fixtures).
  2. DOTFILES_ENV: 'omarchy' (set by the root orchestrator).
  3. Auto-detection: probe the host PATH in this fixed order:
       yay    → omarchy   (AUR helper is the documented Omarchy entry)
       pacman → omarchy   (with WARN: install yay for AUR access)
     If neither of these is on PATH, this script exits non-zero with
     "Could not detect a supported package manager".

Options:
  --dry-run    Print what would be installed without running the
               package manager. Re-running the actual install is a
               no-op when every package is already present.
  --help, -h   Show this help and exit.

Packages (verified with the package manager, not 'command -v'):

  Omarchy: ${OMARCHY_PACKAGES[*]}
EOF
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
while [[ $# -gt 0 ]]; do
    case "$1" in
        --omarchy)
            DOTFILES_ENV_LOCAL="omarchy"
            shift
            ;;
        --dry-run)
            DRY_RUN=1
            shift
            ;;
        --help | -h)
            REQUEST_HELP=1
            shift
            ;;
        *)
            echo "Unknown argument: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

if [[ "$REQUEST_HELP" -eq 1 ]]; then
    usage
    exit 0
fi

# Promote DOTFILES_DRY_RUN=1 to DRY_RUN=1 when invoked by the orchestrator
# without an explicit --dry-run flag. The root setup exports it explicitly
# when --dry-run is set; both signals agree in that case.
if [[ -n "${DOTFILES_DRY_RUN:-}" && "$DOTFILES_DRY_RUN" == "1" ]]; then
    DRY_RUN=1
fi

# ---------------------------------------------------------------------------
# Logging helpers
# ---------------------------------------------------------------------------
log() {
    echo "[setup-deps] $*"
}

warn() {
    echo "[setup-deps] WARN: $*" >&2
}

fail() {
    echo "[setup-deps] ERROR: $*" >&2
    exit 1
}

# ---------------------------------------------------------------------------
# Environment detection
# ---------------------------------------------------------------------------
# Probe package managers in the documented order. Echoes the detected
# env ("omarchy") on stdout. Returns 0 on success, 1 when no supported
# package manager is on PATH. Detection is purely a probe: the script
# never calls `command -v` on a tool it then needs to install.
detect_env() {
    if command -v yay >/dev/null 2>&1; then
        printf 'omarchy\n'
        return 0
    fi
    if command -v pacman >/dev/null 2>&1; then
        warn "yay is not on PATH; install it for AUR access. Detecting as omarchy via pacman."
        printf 'omarchy\n'
        return 0
    fi
    return 1
}

# ---------------------------------------------------------------------------
# Validation
# ---------------------------------------------------------------------------
# When neither an explicit flag nor DOTFILES_ENV is set, auto-detect
# the host by probing package managers. When detection fails, exit
# with a clear, actionable message.
if [[ -z "$DOTFILES_ENV_LOCAL" ]]; then
    if detected_env="$(detect_env)"; then
        DOTFILES_ENV_LOCAL="$detected_env"
        log "Detected env: $DOTFILES_ENV_LOCAL (no --omarchy passed)"
    else
        cat >&2 <<EOF
ERROR: Could not detect a supported package manager (yay, pacman). Install one and re-run.
EOF
        usage >&2
        exit 2
    fi
fi

# ---------------------------------------------------------------------------
# Package manager helpers
# ---------------------------------------------------------------------------
# Reason: replaced by install_batch in change setup-deps-batch-install
