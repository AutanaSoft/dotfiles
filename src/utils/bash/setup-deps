# Verify a package is installed using the native package manager.
# Returns 0 if installed, non-zero otherwise. In dry-run mode, missing
# verification tooling does not fail; the package is conservatively
# treated as missing so the dry-run report still shows the would-be
# install command.
pkg_installed() {
    local pkg="$1"
    if ! command -v pacman >/dev/null 2>&1; then
        if [[ "$DRY_RUN" -eq 1 ]]; then
            warn "pacman not on PATH; cannot verify '$pkg' in dry-run. Assuming missing."
            return 1
        fi
        fail "pacman is not on PATH; cannot verify packages on Omarchy."
    fi
    pacman -Q "$pkg" >/dev/null 2>&1
}

