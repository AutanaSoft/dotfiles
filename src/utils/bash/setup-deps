# ---------------------------------------------------------------------------
# Batch install (single-pass per env)
# ---------------------------------------------------------------------------
# Iterate the env package list, log a per-pkg [ok]/[miss] line, and
# append every missing package to the MISSING=() array. Bumps the
# present / missing counters. Does NOT invoke the package manager.
collect_missing() {
    local pkg
    for pkg in "$@"; do
        if pkg_installed "$pkg"; then
            log "  [ok]   $pkg"
            present=$((present + 1))
        else
            log "  [miss] $pkg"
            MISSING+=("$pkg")
            missing=$((missing + 1))
        fi
    done
}

# Invoke the env's package manager exactly once with every package in
# MISSING=() as a positional argument. In dry-run mode, log the would-be
# command and return 0. In real mode, require the PM on PATH up front
# and exec the command. set -e propagates a non-zero exit; a single
# failure aborts the run.
install_batch() {
    local cmd=(yay -S --needed "${MISSING[@]}")

    if [[ "$DRY_RUN" -eq 1 ]]; then
        log "[dry-run] would run: ${cmd[*]}"
        return 0
    fi

    if ! command -v yay >/dev/null 2>&1; then
        fail "yay is not on PATH; install it before running setup-deps for Omarchy."
    fi

    log "Running: ${cmd[*]}"
    "${cmd[@]}"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
    local packages=("${OMARCHY_PACKAGES[@]}")

    log "Repo root: $REPO_ROOT"
    log "Env:       $DOTFILES_ENV_LOCAL"
    if [[ "$DRY_RUN" -eq 1 ]]; then
        log "Mode:      DRY-RUN (no package manager actions)"
    fi

    log "Checking ${#packages[@]} package(s)..."

    # Batch install state. Counters are script-scoped (not local) so
    # collect_missing can mutate them.
    MISSING=()
    installed=0
    present=0
    missing=0

    collect_missing "${packages[@]}"

    # All-present early-exit: log and exit BEFORE the install call.
    # The final Summary: line is intentionally NOT emitted in this
    # path (nothing was installed; reporting counts is noise).
    if [[ "${#MISSING[@]}" -eq 0 ]]; then
        log "All ${#packages[@]} packages present; nothing to install."
        exit 0
    fi

    log "Installing ${#MISSING[@]} missing: ${MISSING[*]}"
    install_batch

    # Reaching here means install_batch exited 0: every package in
    # MISSING=() was installed successfully. Roll the missing count
    # into installed and clear missing.
    installed=${#MISSING[@]}
    missing=0

    log "Summary: $installed installed, $present present, $missing missing."

    log "Setup complete."
}

main "$@"
