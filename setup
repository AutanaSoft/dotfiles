#!/usr/bin/env bash
# setup — root thin dispatcher for this dotfiles repo.
#
# This is the single entrypoint for new-machine setup. It is intentionally
# minimal: parse flags, validate them, define and export the DOTFILES_*
# path variables that child scripts need, register a trap to clean those
# variables on every exit path, and dispatch to exactly ONE env or helper
# script.
#
# Boundary:
#   - Env scripts (src/utils/bash/setup-dots) own their own full env flow.
#     They call setup-deps and setup-fonts from inside their own main()
#     and pre-flight their own pre-requisites.
#   - src/utils/bash/setup-deps auto-detects the host environment by probing
#     the available package managers (yay/pacman → omarchy). --dots remains
#     valid as an explicit override.
#   - Root MUST NOT run a multi-step deps → fonts → env pipeline. It MUST
#     NOT define run_deps / run_fonts / run_env helpers. It MUST NOT
#     maintain a TOTAL_STEPS counter.
#
# Flags:
#   --dots       — dispatch to src/utils/bash/setup-dots
#   --fonts      — dispatch to src/utils/bash/setup-fonts (or absorbed by --dots)
#   --deps       — dispatch to src/utils/bash/setup-deps   (or absorbed by --dots)
#   --locale     — dispatch to src/utils/bash/setup-locale (standalone only;
#                  NOT absorbed by --dots because locale is user-specific and
#                  must stay opt-in)
#   --dry-run    — set DOTFILES_DRY_RUN=1; env scripts honor it
#   --help / -h  — show usage and exit 0
#
# Precedence:
#   - --dots absorbs --fonts and --deps. The env script handles them.
#   - --locale is a standalone helper, never absorbed by --dots.
#   - With no env flag, --fonts, --deps, and --locale are direct
#     dispatches. Only one standalone helper may be passed at a time.
#
# On any exit path (success, child-script failure, parse error, --help,
# interrupt) the EXIT trap unsets the five DOTFILES_* variables so they
# never leak into the calling shell.
#
# Examples:
#   ./setup --dots                        # dispatch to setup-dots
#   ./setup --dots --fonts                # absorbed; env script handles fonts
#   ./setup --dots --deps                 # absorbed; env script handles deps
#   ./setup --fonts                       # dispatch to setup-fonts
#   ./setup --deps                        # dispatch to setup-deps (auto-detect)
#   ./setup --locale                      # dispatch to setup-locale (opt-in)
#   ./setup --dry-run --dots              # dry-run the env flow
#   ./setup --unknown                     # unknown flag, non-zero exit

set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve repo root from this script's path (CWD-independent).
# ---------------------------------------------------------------------------
SCRIPT_PATH="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_ROOT="$SCRIPT_PATH"
SCRIPTS_DIR="$DOTFILES_ROOT/src/utils/bash"

# ---------------------------------------------------------------------------
# Per-run paths (computed once, exported, cleaned by trap).
#   DOTFILES_BACKUP_DIR  : $DOTFILES_ROOT/backup/<utc-ts>/ (per-run)
#   DOTFILES_FONTS_DIR   : centralized so the literal appears once.
#                          Child scripts (setup-fonts and setup-dots)
#                          read it; do not re-derive in those scripts.
# ---------------------------------------------------------------------------
DOTFILES_BACKUP_DIR="$DOTFILES_ROOT/backup/$(date -u +%Y%m%dT%H%M%SZ)"
DOTFILES_FONTS_DIR="$HOME/.local/share/fonts/autanasoft"

# ---------------------------------------------------------------------------
# Parse state
# ---------------------------------------------------------------------------
DOTFILES_ENV=""
PARSED_DRY_RUN=0
REQUEST_HELP=0
REQUEST_FONTS=0
REQUEST_DEPS=0
REQUEST_LOCALE=0

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
    cat <<EOF
Usage: $0 [--dots] [--fonts] [--deps] [--locale] [--dry-run] [--help]

Thin dispatcher: parse flags, export the DOTFILES_* path variables,
register a cleanup trap, and invoke exactly one env or helper script.
Env scripts own their own full flow; src/utils/bash/setup-deps
auto-detects the host by probing package managers.

Precedence:
  --dots absorbs --fonts and --deps (the env script handles them).
  --locale is a standalone helper, never absorbed by --dots: the
  locale is user-specific and must stay opt-in for forks/siblings.
  Without an env flag, --fonts, --deps, and --locale are direct
  dispatches. Only one standalone helper may be passed at a time.

Environment (one of, or none):
  --dots          Dispatch to src/utils/bash/setup-dots

Options (optional):
  --fonts         Dispatch to src/utils/bash/setup-fonts (absorbed by --dots)
  --deps          Dispatch to src/utils/bash/setup-deps   (absorbed by --dots)
  --locale        Dispatch to src/utils/bash/setup-locale (standalone only;
                  generates the LANG declared in src/etc/locale.conf and
                  installs it to /etc/locale.conf)
  --dry-run       Set DOTFILES_DRY_RUN=1; env scripts honor it
  --help, -h      Show this help and exit

Exported variables (unset on every exit path via EXIT trap):
  DOTFILES_ROOT        Absolute path to the repo root
  DOTFILES_ENV         "omarchy" when --dots is set; unset otherwise
  DOTFILES_DRY_RUN     "1" when --dry-run is set; unset otherwise
  DOTFILES_BACKUP_DIR  Per-run backup dir under \$DOTFILES_ROOT/backup
  DOTFILES_FONTS_DIR   \$HOME/.local/share/fonts/autanasoft (centralized)

Examples:
  $0 --dots
  $0 --dots --fonts             # absorbed; env script handles fonts
  $0 --dots --deps              # absorbed; env script handles deps
  $0 --fonts
  $0 --deps                     # setup-deps auto-detects the host
  $0 --locale                   # opt-in locale install (es_VE.UTF-8 by default)
  $0 --dry-run --dots
EOF
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
while [[ $# -gt 0 ]]; do
    case "$1" in
        --dots)
            DOTFILES_ENV="omarchy"
            shift
            ;;
        --fonts | --font)
            REQUEST_FONTS=1
            shift
            ;;
        --deps)
            REQUEST_DEPS=1
            shift
            ;;
        --locale)
            REQUEST_LOCALE=1
            shift
            ;;
        --dry-run)
            PARSED_DRY_RUN=1
            shift
            ;;
        --help | -h)
            REQUEST_HELP=1
            shift
            ;;
        *)
            echo "Unknown argument: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

if [[ "$REQUEST_HELP" -eq 1 ]]; then
    usage
    exit 0
fi

# ---------------------------------------------------------------------------
# Validation
# ---------------------------------------------------------------------------
# Count active standalone helper flags (mutually exclusive).
standalone_count=$((REQUEST_FONTS + REQUEST_DEPS + REQUEST_LOCALE))

# At least one target must be selected.
if [[ -z "$DOTFILES_ENV" && "$standalone_count" -eq 0 ]]; then
    echo "ERROR: choose --dots, --fonts, --deps, --locale, or any combination." >&2
    usage >&2
    exit 2
fi

# Only one standalone helper may be passed at a time.
if [[ "$standalone_count" -gt 1 ]]; then
    echo "ERROR: choose only one standalone helper: --fonts, --deps, or --locale." >&2
    usage >&2
    exit 2
fi

# ---------------------------------------------------------------------------
# Export the variable contract. Child scripts read these and MUST NOT
# re-derive the repo root or the fonts directory when the env vars are
# set.
# ---------------------------------------------------------------------------
export DOTFILES_ROOT
export DOTFILES_ENV
export DOTFILES_FONTS_DIR
export DOTFILES_BACKUP_DIR

# DOTFILES_DRY_RUN is exported only when --dry-run was passed, so
# sub-scripts (which check the env var) see a clean state. Use the
# separate parse-time flag (PARSED_DRY_RUN) for all internal logic so
# `set -u` never trips on an unset name.
unset DOTFILES_DRY_RUN
if [[ "$PARSED_DRY_RUN" -eq 1 ]]; then
    export DOTFILES_DRY_RUN=1
fi

# ---------------------------------------------------------------------------
# Cleanup trap
# ---------------------------------------------------------------------------
# Fires on every exit path: success, fail, parse error, child-script
# non-zero, interrupt. The dispatcher unsets exactly the five variables
# it exported, so they never leak into the calling shell.
trap 'unset DOTFILES_ROOT DOTFILES_ENV DOTFILES_DRY_RUN DOTFILES_BACKUP_DIR DOTFILES_FONTS_DIR' EXIT

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
# --locale is a standalone helper and is intentionally NOT absorbed by
# --dots (locale is user-specific and must stay opt-in). If the user
# passes both, surface a one-line note so the dropped flag is not
# silent; the dispatch still proceeds to setup-dots.
if [[ -n "$DOTFILES_ENV" && "$REQUEST_LOCALE" -eq 1 ]]; then
    echo "[setup] Note: --locale is standalone-only and is not run by --dots. Run './setup --locale' separately."
fi

# Exactly one target script. Order:
#   1. --dots dispatches to src/utils/bash/setup-dots. --fonts and
#      --deps are absorbed — the env script owns the full flow.
#      --locale is NOT absorbed: it stays opt-in.
#   2. --fonts   dispatches to src/utils/bash/setup-fonts.
#   3. --deps    dispatches to src/utils/bash/setup-deps   (auto-detects).
#   4. --locale  dispatches to src/utils/bash/setup-locale.
target_script=""
case "$DOTFILES_ENV:$REQUEST_FONTS:$REQUEST_DEPS:$REQUEST_LOCALE" in
    omarchy:*:*:*)
        target_script="$SCRIPTS_DIR/setup-dots"
        ;;
    :1:0:0)
        target_script="$SCRIPTS_DIR/setup-fonts"
        ;;
    :0:1:0)
        target_script="$SCRIPTS_DIR/setup-deps"
        ;;
    :0:0:1)
        target_script="$SCRIPTS_DIR/setup-locale"
        ;;
    *)
        # Should be unreachable: validation above already rejected every
        # other combination. Fail loud if a future flag change breaks
        # the table.
        echo "ERROR: internal dispatch table has no entry for '$DOTFILES_ENV:$REQUEST_FONTS:$REQUEST_DEPS:$REQUEST_LOCALE'." >&2
        exit 2
        ;;
esac

if [[ ! -e "$target_script" ]]; then
    echo "ERROR: target script not found: $target_script" >&2
    exit 1
fi
if [[ ! -x "$target_script" ]]; then
    echo "ERROR: target script is not executable: $target_script (run: chmod +x $target_script)" >&2
    exit 1
fi

# Subprocess args: forward --dry-run. Child scripts (setup-deps,
# setup-fonts, setup-dots, setup-locale) all accept it.
declare -a child_args=()
if [[ "$PARSED_DRY_RUN" -eq 1 ]]; then
    child_args=(--dry-run)
fi

echo "[setup] Dispatching to: $(basename -- "$target_script")"

# Invoke; let the child's exit propagate. The EXIT trap fires on the
# way out and cleans the five DOTFILES_* vars.
"$target_script" "${child_args[@]}"
