#!/usr/bin/env bash
# setup — root orchestrator for applying this repo to a target environment.
#
# This is the single entrypoint for new-machine setup. It dispatches to
# the executor scripts in `scripts/` in the correct order:
#
#   1. scripts/setup-deps               — install OS packages (auto, when an env is set)
#   2. (optional) scripts/setup-fonts   — Nerd Fonts
#   3. scripts/setup-<env>              — environment-specific symlinks
#
# The dependency step runs automatically whenever an environment is
# selected (no separate --deps flag). When `--fonts` is used alone
# without an env, the dependency step is skipped — only fonts are
# installed.
#
# The Omarchy executor exists today; the Fedora executor is not implemented
# yet. `./setup --fedora` (with or without --fonts) installs Fedora
# packages via `scripts/setup-deps` and then warns + skips the env step
# (exit 0). This avoids a "mutate then fail" pattern. Manual Fedora setup
# is documented in fedora/README.md.
#
# Examples:
#   ./setup --fonts                       # install fonts only (no deps)
#   ./setup --omarchy                     # install deps, then apply Omarchy env
#   ./setup --omarchy --fonts             # deps, fonts, then Omarchy env
#   ./setup --fedora                      # install Fedora deps, then warn + skip env
#   ./setup --fedora --fonts              # deps, fonts, then warn + skip env
#   ./setup --dry-run --omarchy --fonts   # preview every action

set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve repo root from this script's path (CWD-independent).
# ---------------------------------------------------------------------------
SCRIPT_PATH="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_ROOT="$SCRIPT_PATH"
SCRIPTS_DIR="$DOTFILES_ROOT/scripts"

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------
DOTFILES_ENV=""
PARSED_DRY_RUN=0
REQUEST_FONTS=0
REQUEST_HELP=0
ENV_FLAG_COUNT=0

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
    cat <<EOF
Usage: $0 [--omarchy|--fedora] [--fonts] [--dry-run] [--help]

Apply this dotfiles repo to a target environment.

When an environment flag is given, the dependency step runs
automatically and installs the required OS packages via the env's
native package manager.
There is no separate --deps flag.

Environment (optional when only installing fonts):
  --omarchy       Apply the Omarchy env configuration. System
                  packages are installed via 'yay -S --needed'.
  --fedora        Apply the Fedora env configuration. System
                  packages are installed via 'sudo dnf install -y'.
                  Note: the Fedora env executor is not implemented
                  yet; the env step is skipped with a clear message.

Options:
  --fonts, --font Install Nerd Fonts (Monaspace, FiraCode, FiraMono) into
                  \$HOME/.local/share/fonts/autanasoft/. Runs AFTER the
                  dependency step and BEFORE the env configuration step.
  --dry-run       Print the actions that would run; do not modify the
                  system, download files, or run yay / dnf / omarchy /
                  hyprctl.
  --help, -h      Show this help and exit.

Execution order: deps -> fonts -> env (when an env is selected).
With only --fonts, the order is just fonts (deps is skipped).

Environment variables exported to executor scripts:
  DOTFILES_ROOT       Absolute path to the repo root.
  DOTFILES_ENV        Selected environment (omarchy | fedora).
  DOTFILES_DRY_RUN    "1" when --dry-run was passed, otherwise unset.
  DOTFILES_BACKUP_DIR Per-run backup directory under \$DOTFILES_ROOT/backup.

Examples:
  $0 --fonts
  $0 --omarchy
  $0 --omarchy --fonts
  $0 --fedora
  $0 --fedora --fonts
  $0 --dry-run --omarchy --fonts
EOF
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
while [[ $# -gt 0 ]]; do
    case "$1" in
        --omarchy)
            DOTFILES_ENV="omarchy"
            ENV_FLAG_COUNT=$((ENV_FLAG_COUNT + 1))
            shift
            ;;
        --fedora)
            DOTFILES_ENV="fedora"
            ENV_FLAG_COUNT=$((ENV_FLAG_COUNT + 1))
            shift
            ;;
        --fonts | --font)
            REQUEST_FONTS=1
            shift
            ;;
        --dry-run)
            PARSED_DRY_RUN=1
            shift
            ;;
        --help | -h)
            REQUEST_HELP=1
            shift
            ;;
        *)
            echo "Unknown argument: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

if [[ "$REQUEST_HELP" -eq 1 ]]; then
    usage
    exit 0
fi

# ---------------------------------------------------------------------------
# Validation
# ---------------------------------------------------------------------------
if [[ "$ENV_FLAG_COUNT" -eq 0 && "$REQUEST_FONTS" -eq 0 ]]; then
    echo "ERROR: choose an environment (--omarchy or --fedora), --fonts, or both." >&2
    usage >&2
    exit 2
fi

if [[ "$ENV_FLAG_COUNT" -gt 1 ]]; then
    echo "ERROR: --omarchy and --fedora are mutually exclusive." >&2
    usage >&2
    exit 2
fi

# ---------------------------------------------------------------------------
# Logging helpers
# ---------------------------------------------------------------------------
log() {
    echo "[setup] $*"
}

warn() {
    echo "[setup] WARN: $*" >&2
}

fail() {
    echo "[setup] ERROR: $*" >&2
    exit 1
}

# ---------------------------------------------------------------------------
# Sanity checks
# ---------------------------------------------------------------------------
if [[ ! -d "$SCRIPTS_DIR" ]]; then
    fail "Scripts directory not found: $SCRIPTS_DIR"
fi

# ---------------------------------------------------------------------------
# Export context for executor scripts.
#   - DOTFILES_ROOT     : repo root (executor scripts use it instead of
#                         resolving their own location when set).
#   - DOTFILES_ENV      : omarchy | fedora
#   - DOTFILES_DRY_RUN  : "1" only when --dry-run was passed.
#   - DOTFILES_BACKUP_DIR : per-run backup directory; executors that back
#                         up before replacing symlinks can place files
#                         here. The directory itself is not created unless
#                         a real (non-dry-run) backup happens.
# ---------------------------------------------------------------------------
export DOTFILES_ROOT
export DOTFILES_ENV

# Export DOTFILES_DRY_RUN only when --dry-run was passed, so executors
# (which check the env var) see a clean state. Use the separate parse-time
# flag (PARSED_DRY_RUN) for all internal logic so `set -u` never trips on
# an unset name.
unset DOTFILES_DRY_RUN
if [[ "$PARSED_DRY_RUN" -eq 1 ]]; then
    export DOTFILES_DRY_RUN=1
fi

DOTFILES_BACKUP_DIR="$DOTFILES_ROOT/backup/$(date -u +%Y%m%dT%H%M%SZ)"
export DOTFILES_BACKUP_DIR

# ---------------------------------------------------------------------------
# Dispatch helpers
# ---------------------------------------------------------------------------
run_deps() {
    local env="$1"
    local step="$2"
    local script="$SCRIPTS_DIR/setup-deps"
    if [[ ! -e "$script" ]]; then
        fail "Deps script not found: $script"
    fi
    if [[ ! -x "$script" ]]; then
        fail "Deps script is not executable: $script (run: chmod +x $script)"
    fi

    if [[ "$PARSED_DRY_RUN" -eq 1 ]]; then
        log "Step $step/$TOTAL_STEPS: install dependencies for $env (dry-run)"
        "$script" --dry-run
    else
        log "Step $step/$TOTAL_STEPS: install dependencies for $env"
        "$script"
    fi
}

run_fonts() {
    local step="$1"
    local script="$SCRIPTS_DIR/setup-fonts"
    if [[ ! -e "$script" ]]; then
        fail "Fonts script not found: $script"
    fi
    if [[ ! -x "$script" ]]; then
        fail "Fonts script is not executable: $script (run: chmod +x $script)"
    fi

    if [[ "$PARSED_DRY_RUN" -eq 1 ]]; then
        log "Step $step/$TOTAL_STEPS: install fonts (dry-run)"
        "$script" --dry-run
    else
        log "Step $step/$TOTAL_STEPS: install fonts"
        "$script"
    fi
}

run_env() {
    local env="$1"
    local step="$2"
    case "$env" in
        omarchy)
            local script="$SCRIPTS_DIR/setup-omarchy"
            if [[ ! -e "$script" ]]; then
                fail "Omarchy script not found: $script"
            fi
            if [[ ! -x "$script" ]]; then
                fail "Omarchy script is not executable: $script (run: chmod +x $script)"
            fi
            if [[ "$PARSED_DRY_RUN" -eq 1 ]]; then
                log "Step $step/$TOTAL_STEPS: apply Omarchy env (dry-run)"
                "$script" --dry-run
            else
                log "Step $step/$TOTAL_STEPS: apply Omarchy env"
                "$script"
            fi
            ;;
        fedora)
            local script="$SCRIPTS_DIR/setup-fedora"
            if [[ ! -e "$script" ]]; then
                # Fedora env executor is not implemented yet. The deps
                # step (and fonts, when --fonts was passed) already ran
                # before we got here, so skip the env step with a clear
                # warning and exit 0 instead of failing after mutating
                # the system. Manual setup is documented in
                # fedora/README.md.
                local what_done
                if [[ "$PARSED_DRY_RUN" -eq 1 ]]; then
                    what_done="previewed"
                else
                    what_done="installed"
                fi
                warn "Fedora env executor is not implemented yet (no scripts/setup-fedora present). Dnf packages were $what_done; skipping env configuration. See fedora/README.md for manual setup."
                log "Step $step/$TOTAL_STEPS: skip Fedora env (not implemented)"
                return 0
            fi
            # If the script exists in the future, this branch runs it.
            if [[ ! -x "$script" ]]; then
                fail "Fedora script is not executable: $script (run: chmod +x $script)"
            fi
            if [[ "$PARSED_DRY_RUN" -eq 1 ]]; then
                log "Step $step/$TOTAL_STEPS: apply Fedora env (dry-run)"
                "$script" --dry-run
            else
                log "Step $step/$TOTAL_STEPS: apply Fedora env"
                "$script"
            fi
            ;;
        *)
            fail "Unknown environment: $env"
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
# Compute the total step count up front so the "Step X/Y" labels stay
# accurate regardless of which combination of flags was passed:
#   - env only      -> 2 steps (deps, env)
#   - fonts only    -> 1 step  (fonts)
#   - env + fonts   -> 3 steps (deps, fonts, env)
TOTAL_STEPS=0
if [[ -n "$DOTFILES_ENV" ]]; then
    TOTAL_STEPS=$((TOTAL_STEPS + 1))   # deps
fi
if [[ "$REQUEST_FONTS" -eq 1 ]]; then
    TOTAL_STEPS=$((TOTAL_STEPS + 1))   # fonts
fi
if [[ -n "$DOTFILES_ENV" ]]; then
    TOTAL_STEPS=$((TOTAL_STEPS + 1))   # env
fi

log "Repo root:  $DOTFILES_ROOT"
if [[ -n "$DOTFILES_ENV" ]]; then
    log "Env:        $DOTFILES_ENV"
else
    log "Env:        none"
fi
if [[ "$PARSED_DRY_RUN" -eq 1 ]]; then
    log "Mode:       DRY-RUN (no system changes)"
fi
if [[ "$REQUEST_FONTS" -eq 1 ]]; then
    log "Fonts:      yes (after deps, before env)"
else
    log "Fonts:      no"
fi
log "Steps:      $TOTAL_STEPS (deps -> fonts -> env)"
log "Backup dir: $DOTFILES_BACKUP_DIR"

current_step=0

# 1) Deps (only when an env is selected). Runs first so fonts and the
# env executor can rely on every required package being present.
if [[ -n "$DOTFILES_ENV" ]]; then
    current_step=$((current_step + 1))
    run_deps "$DOTFILES_ENV" "$current_step"
fi

# 2) Fonts (only when --fonts was passed). Skipped entirely when no env
# is selected, so `./setup --fonts` stays a fonts-only command.
if [[ "$REQUEST_FONTS" -eq 1 ]]; then
    current_step=$((current_step + 1))
    run_fonts "$current_step"
fi

# 3) Env executor (only when an env is selected).
if [[ -n "$DOTFILES_ENV" ]]; then
    current_step=$((current_step + 1))
    run_env "$DOTFILES_ENV" "$current_step"
fi

log "Setup complete."
