# Dotfiles symlink manifest
# Format: <action> <source-relative-to-repo> <target-relative-to-home>
#
# Actions:
#   dir   - symlink entire directory
#   file  - symlink single file
#   glob  - expand wildcard pattern (e.g., *.conf)
#   copy  - copy file instead of symlink (local file has priority)
#   skip  - explicit exclusion (files exist in repo but not managed)
#
# Notes:
#   - Paths are relative to $REPO_ROOT (source) and $HOME (target)
#   - Comments start with #
#   - Empty lines are ignored
#   - Tab-separated fields

# --- Directory symlinks ---
dir	omarchy/home/config/bash	.config/bash
dir	omarchy/home/config/nvim	.config/nvim
dir	omarchy/home/config/omarchy/themes/tokyo-night-autana	.config/omarchy/themes/tokyo-night-autana
dir	omarchy/home/config/mise	.config/mise
dir	omarchy/home/config/tmux	.config/tmux

# --- File symlinks ---
file	omarchy/home/config/waybar/config.jsonc	.config/waybar/config.jsonc
file	omarchy/home/config/alacritty/alacritty.toml	.config/alacritty/alacritty.toml
file	omarchy/home/config/starship.toml	.config/starship.toml
file	omarchy/home/bashrc	.bashrc

# --- Wildcard symlinks (expand pattern) ---
glob	omarchy/home/config/hypr/*.conf	.config/hypr/

# --- Copy instead of symlink (local file has priority) ---
copy	omarchy/home/ssh/config	.ssh/config

# --- Explicit exclusions ---
skip	omarchy/home/local/bin/monitor	-
skip	omarchy/home/config/mako/	-
skip	omarchy/home/config/omarchy/hooks/	-
