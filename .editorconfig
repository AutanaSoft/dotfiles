# EditorConfig: https://editorconfig.org
#
# EditorConfig helps maintain consistent coding styles across different
# editors and IDEs. This file defines project-wide formatting rules
# that supported editors will automatically apply.
#
# AI agents working in this repo (such as opencode) should respect
# these rules when generating or editing files. The file is at the
# repo root for easy discovery.

# root = true stops EditorConfig from searching for .editorconfig files
# in parent directories. This makes this file the authoritative source.
root = true

# ============================================================================
# DEFAULT RULES — Apply to all files unless overridden below
# ============================================================================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

# ============================================================================
# JAVASCRIPT / TYPESCRIPT — Web development files
# ============================================================================
[*.{js,jsx,ts,tsx}]
max_line_length = 120
quote_type = single
ij_typescript_use_double_quotes = false

# ============================================================================
# MARKDOWN — Documentation files
# ============================================================================
# Markdown uses trailing spaces for hard line breaks; don't trim.
[*.{md,markdown}]
max_line_length = 100
trim_trailing_whitespace = false

# ============================================================================
# PYTHON — PEP 8 compliant settings
# ============================================================================
[*.py]
indent_size = 4
max_line_length = 79

# ============================================================================
# MAKEFILE — Build configuration
# ============================================================================
# Makefiles require tabs (recipe lines must start with TAB).
# Using spaces will cause "missing separator" errors.
[Makefile]
indent_style = tab
