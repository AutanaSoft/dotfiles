# EditorConfig: https://editorconfig.org
#
# AI agents working in this repo (such as opencode) should respect
# these rules when generating or editing files. The file is at the
# repo root for easy discovery.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

[*.{js,jsx,ts,tsx}]
max_line_length = 120
quote_type = single
ij_typescript_use_double_quotes = false

# Markdown uses trailing spaces for hard line breaks; don't trim.
[*.{md,markdown}]
max_line_length = 100
trim_trailing_whitespace = false

[*.py]
indent_size = 4
max_line_length = 79

# Makefiles require tabs (recipe lines must start with TAB).
[Makefile]
indent_style = tab

