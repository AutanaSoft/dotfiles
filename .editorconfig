# EditorConfig: https://editorconfig.org
#
# EditorConfig helps maintain consistent coding styles across different
# editors and IDEs. This file defines project-wide formatting rules
# that supported editors will automatically apply.
#
# AI agents working in this repo (such as opencode) should respect
# these rules when generating or editing files. The file is at the
# repo root for easy discovery.

# root = true stops EditorConfig from searching for .editorconfig files
# in parent directories. This makes this file the authoritative source.
root = true

# ============================================================================
# DEFAULT RULES — Apply to all files unless overridden below
# ============================================================================
[*]
charset = utf-8                    # File encoding
end_of_line = lf                   # Line endings: LF (Unix-style)
insert_final_newline = true        # Ensure files end with a newline
trim_trailing_whitespace = true    # Remove trailing spaces on lines
indent_style = space               # Use spaces, not tabs
indent_size = 2                    # 2 spaces per indentation level
max_line_length = 100              # Soft limit for line length

# ============================================================================
# JAVASCRIPT / TYPESCRIPT — Web development files
# ============================================================================
[*.{js,jsx,ts,tsx}]
max_line_length = 120              # Wider limit for JS/TS (more readable)
quote_type = single                # Prefer single quotes: 'text'
ij_typescript_use_double_quotes = false  # IntelliJ IDEA: disable double quotes

# ============================================================================
# MARKDOWN — Documentation files
# ============================================================================
# Markdown uses trailing spaces for hard line breaks; don't trim.
[*.{md,markdown}]
max_line_length = 100              # Keep lines reasonably short for readability
trim_trailing_whitespace = false   # Preserve trailing spaces (used for line breaks)

# ============================================================================
# PYTHON — PEP 8 compliant settings
# ============================================================================
[*.py]
indent_size = 4                    # PEP 8 standard: 4 spaces
max_line_length = 79               # PEP 8 standard: 79 characters

# ============================================================================
# MAKEFILE — Build configuration
# ============================================================================
# Makefiles require tabs (recipe lines must start with TAB).
# Using spaces will cause "missing separator" errors.
[Makefile]
indent_style = tab                 # Tabs are mandatory for Makefile recipes

